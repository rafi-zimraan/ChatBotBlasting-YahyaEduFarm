# =====================================================
# WHATSAPP AI BOT — Konfigurasi Environment
# =====================================================
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# =====================
# GROQ API KEY (Wajib)
# Daftar gratis di: https://console.groq.com
# =====================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================
# MODEL AI (Opsional)
# Default: llama-3.1-8b-instant
# Pilihan lain: llama-3.3-70b-versatile, mixtral-8x7b-32768
# =====================
GROQ_MODEL=llama-3.1-8b-instant

# =====================
# MAX TOKENS (Opsional)
# Default: 250
# Semakin besar = jawaban lebih panjang = lebih banyak token terpakai
# =====================
MAX_TOKENS=250

# =====================
# ADMIN ID (Wajib)
# Nomor admin untuk menerima notifikasi handover (format: XXXXXXXXXXXX@lid)
# di dapat dari log
ADMIN_ID=5166XXXXXXXXXX@lid

# =====================
# WEB UI PORT (Opsional)
# Default: 3000
# Port untuk dashboard web blasting & group management
# =====================
WEB_PORT=3000

# =====================
# WEB UI LOGIN (Wajib)
# Email dan password untuk login ke dashboard
# =====================
WEB_UI_EMAIL=owner@example.com
WEB_UI_PASSWORD=ganti_dengan_password_kuat

# =====================
# NODE ENV (Opsional)
# Set ke "production" di server untuk aktifkan secure cookie (HTTPS)
# =====================
NODE_ENV=production